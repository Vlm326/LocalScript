# llm-service environment example
# Copy to `llm-service/.env` (local dev) or use Docker Compose `.env`.

# Core endpoints
OLLAMA_URL=http://localhost:11434
SANDBOX_SERVICE_URL=http://localhost:6778

# Ollama models
GENERATION_MODEL=qwen2.5-coder:7b
EMBEDDING_MODEL=bge-m3

# Pipeline behavior
CONFIRM_WORD=CODE_OK
MAX_RETRIES=2
CODE_RETRIES_COUNT=5
CODE_RETRIES_MODEL=2
CODE_RETRIES_SANDBOX=20

# Optional RAG (Qdrant + embeddings service)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=lua_patterns
EMBEDDINGS_URL=http://localhost:8000/v1/embeddings
